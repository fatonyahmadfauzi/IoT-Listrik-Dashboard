{
  "rules": {

    "listrik": {
      ".read": "auth != null && auth.token.isTempAccount !== true",
      "arus":         { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "tegangan":     { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "daya":         { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "energi_kwh":   { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "frekuensi":    { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "power_factor": { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "status":       { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "updated_at":   { ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'" },
      "relay": {
        ".write": "auth != null && (auth.token.email === 'listrik.iot.device@gmail.com' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "logs": {
      ".read":  "auth != null && auth.token.isTempAccount !== true",
      ".write": "auth != null && auth.token.isTempAccount !== true && (auth.token.email === 'listrik.iot.device@gmail.com' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
    },

    "settings": {
      ".read":  "auth != null && auth.token.isTempAccount !== true && (auth.token.email === 'listrik.iot.device@gmail.com' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
      ".write": "auth != null && auth.token.isTempAccount !== true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "deviceBootstrap": {
        "pending": {
          ".write": "auth != null && auth.token.isTempAccount !== true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.token.email === 'listrik.iot.device@gmail.com')"
        },
        "status": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "statusMessage": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "lastSeenAt": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "lastAppliedRequestId": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "lastConfirmedAt": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "lastAction": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "activeSsid": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "deviceIp": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "lastError": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        },
        "restartRequired": {
          ".write": "auth != null && auth.token.email === 'listrik.iot.device@gmail.com'"
        }
      }
    },

    "users": {
      ".read": "auth != null && auth.token.isTempAccount !== true && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid && auth.token.isTempAccount !== true",
        ".write": "auth != null && auth.token.isTempAccount !== true && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".write": "auth != null && auth.token.isTempAccount !== true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && auth.uid === $uid && newData.val() === 'user'))"
        }
      }
    },

    "sim": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid && auth.token.isTempAccount === true",
        ".write": "auth != null && auth.uid === $uid && auth.token.isTempAccount === true"
      }
    },

    "temp_sessions": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": false
      }
    }

  }
}
