<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- ══ Header ════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/appHeader"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard IoT"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvConnectionState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Connecting..."
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/yellow"/>
        </LinearLayout>

        <!-- Temp Session Badge -->
        <LinearLayout
            android:id="@+id/tempBadgeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEMO"
                android:textSize="10sp"
                android:textColor="@color/yellow"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvTempTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:00"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_bolt"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Logout"
            app:tint="@color/text_secondary"/>
    </LinearLayout>

    <!-- ══ SCROLL ════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="28dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/appHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Status Banner ──────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardStatusOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_normal"
                android:padding="24dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEM STATUS"
                    android:letterSpacing="0.1"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"/>
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMUAT..."
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- ── PRIMARY METRICS: Arus + Tegangan (2 kotak sama besar) ── -->
            <!--
                LinearLayout horizontal + layout_weight="1" → kedua kotak
                SELALU sama tinggi karena mereka wrap_content dalam arah yang
                sama, dan LinearLayout stretch keduanya ke max height.
                Untuk equal HEIGHT dari dua wrap_content child, kita set
                android:baselineAligned="false" dan gunakan match_parent
                pada inner layout height.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">

                <!-- Arus Card -->
                <LinearLayout
                    android:id="@+id/cardArus"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Arus (A)"
                        app:drawableStartCompat="@drawable/ic_bolt"
                        android:drawablePadding="6dp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center_vertical"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvArus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:layout_marginTop="8dp"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/cyan"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SCT-013"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <!-- Tegangan Card -->
                <LinearLayout
                    android:id="@+id/cardTegangan"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tegangan"
                        app:drawableStartCompat="@drawable/ic_plug"
                        android:drawablePadding="6dp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center_vertical"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvTegangan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:layout_marginTop="8dp"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ZMPT101B"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── SECONDARY METRICS: Daya / Energi / Sumber (3 sama besar) ── -->
            <!--
                3 kotak dalam 1 baris dengan layout_weight="1" masing-masing.
                match_parent pada height agar semua setinggi yang tertinggi.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:baselineAligned="false">

                <!-- Daya Aktif -->
                <LinearLayout
                    android:id="@+id/cardDaya"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_glass"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daya (W)"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvDayaW"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:layout_marginTop="6dp"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Energi kWh -->
                <LinearLayout
                    android:id="@+id/cardEnergi"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="3dp"
                    android:background="@drawable/bg_glass"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Energi (kWh)"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvEnergiKwh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.000"
                        android:layout_marginTop="6dp"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Sumber Data -->
                <LinearLayout
                    android:id="@+id/cardSumber"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_glass"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sumber"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvDataSource"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLOUD"
                        android:layout_marginTop="6dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/cyan"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ CHART SECTION ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="GRAFIK REALTIME"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <RelativeLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_glass"
                android:padding="8dp">
                <TextView
                    android:id="@+id/tvChartLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Menunggu data..."/>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </RelativeLayout>

            <!-- ══ STATISTIK (20 DATA TERAKHIR) ═══════════════════════════ -->
            <!--
                Menggunakan ConstraintLayout sebagai container agar Flow widget
                dapat me-reference sibling views dengan benar.
                4 kotak: AVG Arus | MAX Arus | AVG Teg | MAX Teg  →  2 kolom x 2 baris
            -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="STATISTIK (20 DATA TERAKHIR)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/containerStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_glass"
                android:padding="14dp">

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:constraint_referenced_ids="statAvgArus,statMaxArus,statAvgTeg,statMaxTeg"
                    app:flow_wrapMode="aligned"
                    app:flow_maxElementsWrap="2"
                    app:flow_horizontalGap="10dp"
                    app:flow_verticalGap="10dp"
                    app:flow_horizontalStyle="spread_inside"
                    app:flow_verticalStyle="packed"/>

                <!-- AVG Arus -->
                <LinearLayout
                    android:id="@+id/statAvgArus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG Arus"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvAvgArus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 A"
                        android:textSize="18sp"
                        android:textColor="@color/cyan"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- MAX Arus -->
                <LinearLayout
                    android:id="@+id/statMaxArus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAX Arus"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvMaxArus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 A"
                        android:textSize="18sp"
                        android:textColor="@color/red"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- AVG Tegangan -->
                <LinearLayout
                    android:id="@+id/statAvgTeg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG Teg"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvAvgTeg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 V"
                        android:textSize="18sp"
                        android:textColor="@color/yellow"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- MAX Tegangan -->
                <LinearLayout
                    android:id="@+id/statMaxTeg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_glass"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAX Teg"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/tvMaxTeg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 V"
                        android:textSize="18sp"
                        android:textColor="@color/yellow"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══ RIWAYAT LOG (15 TERAKHIR) ══════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="RIWAYAT LOG (15 TERAKHIR)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:id="@+id/tvHistoryEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Belum ada riwayat."
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="24dp"
                android:background="@drawable/bg_glass"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <!-- ══ RELAY CONTROL (admin only) ══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/relaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Relay Control"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btnRelayOn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/green"
                        android:text="Turn ON"/>
                    <Button
                        android:id="@+id/btnRelayOff"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/red"
                        android:text="Turn OFF"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ DEMO MODE (admin only) ══════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/demoSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thesis Demo Mode (Admin)"
                    app:drawableStartCompat="@drawable/ic_settings"
                    android:drawablePadding="6dp"
                    android:gravity="center_vertical"
                    android:textColor="#f59e0b"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Force override status to trigger alarms locally."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btnDemoNormal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/green"
                        android:text="NORMAL"/>
                    <Button
                        android:id="@+id/btnDemoWarning"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/yellow"
                        android:textColor="#000000"
                        android:text="WARN"/>
                    <Button
                        android:id="@+id/btnDemoDanger"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/red"
                        android:text="DANGER"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
