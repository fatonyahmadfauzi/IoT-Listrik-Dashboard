{
  "name": "iot-listrik-dashboard-electron",
  "version": "1.0.0",
  "description": "IoT Listrik Dashboard Desktop App",
  "author": "Fatony Ahmad Fauzi",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build:icon": "node scripts/create-icon.mjs",
    "build": "npm run build:icon && tsc -p tsconfig.main.json && vite build",
    "postbuild": "copy public\\alarm.wav dist\\alarm.wav",
    "clean:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-before-pack.ps1",
    "build:electron": "npm run build && electron-builder",
    "build:win:setup:ia32": "npm run build && electron-builder --win --ia32",
    "build:win:setup:x64": "npm run build && electron-builder --win --x64",
    "build:win:setup:arm64": "npm run build && electron-builder --win --arm64",
    "build:win:msi:x64": "npm run build && electron-builder --win msi --x64",
    "build:win:portable:ia32": "npm run build && electron-builder --win portable --ia32",
    "build:win:portable:x64": "npm run build && electron-builder --win portable --x64",
    "build:win:portable:arm64": "npm run build && electron-builder --win portable --arm64",
    "build:win:all": "npm run build:win:setup:ia32 && npm run build:win:setup:x64 && npm run build:win:setup:arm64 && npm run build:win:portable:ia32 && npm run build:win:portable:x64 && npm run build:win:portable:arm64",
    "build:win:unified": "npm run build && electron-builder --win --ia32 --x64 --arm64",
    "preview": "vite preview",
    "lint:fix": "eslint . --ext ts,tsx --fix"
  },
  "build": {
    "appId": "com.iotlistrik.dashboard",
    "productName": "IoT Listrik Dashboard",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist-electron",
      "dist",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32",
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "ia32",
            "x64",
            "arm64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "msi": {
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IoT Listrik Dashboard"
    }
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^8.1.1",
    "electron-updater": "^6.1.7",
    "firebase": "^12.11.0",
    "lucide-react": "^0.294.0",
    "react-chartjs-2": "^5.3.1",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "electron": "^25.3.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.27",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.3",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.1",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.12.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "peerDependencies": {
    "react": "^18.2.25",
    "react-dom": "^18.2.25"
  }
}
