{
  "rules": {
    "listrik": {
      ".read": "auth != null",
      "arus":       { ".write": "auth != null && auth.token.email === 'iot-device@yourproject.com'" },
      "tegangan":   { ".write": "auth != null && auth.token.email === 'iot-device@yourproject.com'" },
      "status":     { ".write": "auth != null && auth.token.email === 'iot-device@yourproject.com'" },
      "updated_at": { ".write": "auth != null && auth.token.email === 'iot-device@yourproject.com'" },
      "relay": {
        ".write": "auth != null && (auth.token.email === 'iot-device@yourproject.com' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "logs": {
      ".read":  "auth != null",
      ".write": "auth != null && (auth.token.email === 'iot-device@yourproject.com' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
    },

    "settings": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",

        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",

        "role": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && auth.uid === $uid))"
        }
      }
    }
  }
}
