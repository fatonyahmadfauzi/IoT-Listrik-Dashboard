# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config
firebase-seed.json

# Android signing (do not commit secrets)
platforms/android/keystore/*.jks
platforms/android/keystore/keystore.properties

# Windows/Electron signing (do not commit secrets)
platforms/electron/signing/*.pfx
platforms/electron/signing/*.pem
platforms/electron/signing/*.key
platforms/electron/signing/*.env

# Local Firmware config (contains raw password)
hardware/config.h
# Uncomment this if you'd like others to create their own Firebase project.
# For a team working on the same Firebase project(s), it is recommended to leave
# it commented so all members can deploy to the same project(s) in .firebaserc.
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Android build artifacts
platforms/android/.gradle/
platforms/android/app/build/

# Electron build artifacts
platforms/electron/dist/
platforms/electron/release/
platforms/electron/release-build/
platforms/electron/release-build-all/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# dataconnect generated files
.dataconnect

# service account credentials
**/serviceAccountKey.json

.vercel

# Local downloads and binaries
public/downloads/**/*.exe
public/downloads/**/*.zip
public/downloads/**/*.msi

# Junk binary files
test-msi-download.msi

# CLI Node Build Artifacts
platforms/cli-node/build/
