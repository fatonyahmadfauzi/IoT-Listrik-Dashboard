{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "Modern Electron Desktop App",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc && vite build && electron-builder",
    "build:win:setup:ia32": "npm run build && electron-builder --win --ia32",
    "build:win:setup:x64": "npm run build && electron-builder --win --x64",
    "build:win:setup:arm64": "npm run build && electron-builder --win --arm64",
    "build:win:portable:ia32": "npm run build && electron-builder --win --ia32 --config.portable=true",
    "build:win:portable:x64": "npm run build && electron-builder --win --x64 --config.portable=true",
    "build:win:portable:arm64": "npm run build && electron-builder --win --arm64 --config.portable=true",
    "build:win:all": "npm run build:win:setup:ia32 && npm run build:win:setup:x64 && npm run build:win:setup:arm64 && npm run build:win:portable:ia32 && npm run build:win:portable:x64 && npm run build:win:portable:arm64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^8.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "electron": "^25.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "postcss": "^8.4.27",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.12.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.electron.app",
    "productName": "ElectronApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "dist"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["ia32", "x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["ia32", "x64", "arm64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${arch}.${ext}"
    }
  }
}