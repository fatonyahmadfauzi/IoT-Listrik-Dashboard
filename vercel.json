{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/app/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/app/" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(js|css)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/get-telegram-bot-profile", "destination": "/api/telegram-admin-action?action=profile" },
    { "source": "/api/test-telegram-config",     "destination": "/api/telegram-admin-action?action=test" },

    { "source": "/app/login",     "destination": "/app/login.html" },
    { "source": "/app/dashboard", "destination": "/app/dashboard.html" },
    { "source": "/app/history",   "destination": "/app/history.html" },
    { "source": "/app/settings",  "destination": "/app/settings.html" },
    { "source": "/app/telegram",  "destination": "/app/telegram.html" },
    { "source": "/app/discord",   "destination": "/app/discord.html" },
    { "source": "/app/users",     "destination": "/app/users.html" },

    { "source": "/login",         "destination": "/app/login.html" },
    { "source": "/dashboard",     "destination": "/app/dashboard.html" },
    { "source": "/history",       "destination": "/app/history.html" },
    { "source": "/settings",      "destination": "/app/settings.html" },
    { "source": "/telegram",      "destination": "/app/telegram.html" },
    { "source": "/discord",       "destination": "/app/discord.html" },
    { "source": "/users",         "destination": "/app/users.html" },

    { "source": "/simulator/app",  "destination": "/simulator/app.html" },
    { "source": "/simulator",      "destination": "/simulator/index.html" },
    { "source": "/downloads",      "destination": "/downloads.html" }
  ]
}
