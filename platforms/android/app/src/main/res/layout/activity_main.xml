<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/appHeader"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard IoT"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvConnectionState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Connecting..."
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/yellow"/>
        </LinearLayout>
        
        <!-- New Temp Session Badge -->
        <LinearLayout
            android:id="@+id/tempBadgeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEMO"
                android:textSize="10sp"
                android:textColor="@color/yellow"
                android:letterSpacing="0.05"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvTempTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:00"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>
        </LinearLayout>
        
        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_bolt"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Logout"
            app:tint="@color/text_secondary"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/appHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">
            
            <!-- Animated Status Card -->
            <LinearLayout
                android:id="@+id/cardStatusOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_normal"
                android:padding="24dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEM STATUS"
                    android:letterSpacing="0.1"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"/>
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMUAT..."
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Metrics Grid Flow Engine -->
            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flowMetrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cardStatusOverlay"
                android:layout_marginTop="16dp"
                app:constraint_referenced_ids="cardArus,cardTegangan"
                app:flow_wrapMode="chain"
                app:flow_horizontalGap="16dp"
                app:flow_verticalGap="16dp"/>

            <!-- Arus -->
            <LinearLayout
                android:id="@+id/cardArus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="140dp"
                app:layout_constrainedWidth="true"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arus (A)"
                    app:drawableStartCompat="@drawable/ic_bolt"
                    android:drawablePadding="6dp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center_vertical"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvArus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:layout_marginTop="8dp"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/cyan"/>
            </LinearLayout>

            <!-- Tegangan -->
            <LinearLayout
                android:id="@+id/cardTegangan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="140dp"
                app:layout_constrainedWidth="true"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tegangan"
                    app:drawableStartCompat="@drawable/ic_plug"
                    android:drawablePadding="6dp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center_vertical"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tvTegangan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:layout_marginTop="8dp"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/yellow"/>
            </LinearLayout>

            <!-- Secondary Metrics Flow Engine -->
            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flowSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/flowMetrics"
                android:layout_marginTop="16dp"
                app:constraint_referenced_ids="cardDaya,cardEnergi,cardSumber"
                app:flow_wrapMode="chain"
                app:flow_horizontalGap="12dp"
                app:flow_verticalGap="12dp"/>

            <LinearLayout
                android:id="@+id/cardDaya"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="100dp"
                app:layout_constrainedWidth="true"
                android:background="@drawable/bg_glass"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daya (est W)"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvDayaW"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:layout_marginTop="2dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
            
            <LinearLayout
                android:id="@+id/cardEnergi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="100dp"
                app:layout_constrainedWidth="true"
                android:background="@drawable/bg_glass"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Energi (kWh)"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvEnergiKwh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:layout_marginTop="2dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
            
            <LinearLayout
                android:id="@+id/cardSumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minWidth="100dp"
                app:layout_constrainedWidth="true"
                android:background="@drawable/bg_glass"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sumber"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvDataSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLOUD"
                    android:layout_marginTop="2dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/cyan"/>
            </LinearLayout>

            <!-- Chart Section -->
            <TextView
                android:id="@+id/titleChart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="GRAFIK REALTIME"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/flowSecondary"/>
                
            <RelativeLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="H,16:9"
                app:layout_constraintHeight_min="240dp"
                app:layout_constraintTop_toBottomOf="@id/titleChart"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass"
                android:padding="8dp">
                <TextView
                    android:id="@+id/tvChartLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Menunggu data..." />
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </RelativeLayout>


            <!-- Statistics Block -->
            <TextView
                android:id="@+id/titleStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="STATISTIK (20 DATA TERAKHIR)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/chartContainer"/>

            <LinearLayout
                android:id="@+id/containerStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/titleStats"
                android:orientation="vertical">
                
                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="statAvgArus,statMaxArus,statAvgTeg,statMaxTeg"
                    app:flow_wrapMode="chain"
                    app:flow_horizontalGap="8dp"
                    app:flow_verticalGap="12dp"/>
                    
                <LinearLayout android:id="@+id/statAvgArus" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constrainedWidth="true" android:minWidth="70dp" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AVG Arus" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvAvgArus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 A" android:textSize="14sp" android:textColor="@color/cyan" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/statMaxArus" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constrainedWidth="true" android:minWidth="70dp" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAX Arus" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvMaxArus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 A" android:textSize="14sp" android:textColor="@color/red" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/statAvgTeg" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constrainedWidth="true" android:minWidth="70dp" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AVG Teg" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvAvgTeg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 V" android:textSize="14sp" android:textColor="@color/yellow" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/statMaxTeg" android:layout_width="0dp" android:layout_height="wrap_content" app:layout_constrainedWidth="true" android:minWidth="70dp" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAX Teg" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvMaxTeg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 V" android:textSize="14sp" android:textColor="@color/yellow" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- History Section -->
            <TextView
                android:id="@+id/titleLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="RIWAYAT LOG (15 TERAKHIR)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/containerStats"/>
                
            <TextView
                android:id="@+id/tvHistoryEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Belum ada riwayat."
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="20dp"
                android:background="@drawable/bg_glass"
                app:layout_constraintTop_toBottomOf="@id/titleLog"/>
                
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/titleLog"/>

            <!-- Relay Control -->
            <LinearLayout
                android:id="@+id/relaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/rvHistory">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Relay Control"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btnRelayOn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/green"
                        android:text="Turn ON"/>
                    <Space android:layout_width="16dp" android:layout_height="wrap_content"/>
                    <Button
                        android:id="@+id/btnRelayOff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/red"
                        android:text="Turn OFF"/>
                </LinearLayout>
            </LinearLayout>

    
            <!-- Demo Mode Section -->
            <LinearLayout
                android:id="@+id/demoSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass"
                android:padding="24dp"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/relaySection">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thesis Demo Mode (Admin)"
                    app:drawableStartCompat="@drawable/ic_settings"
                    android:drawablePadding="6dp"
                    android:gravity="center_vertical"
                    android:textColor="#f59e0b"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Force override status to trigger alarms locally."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btnDemoNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/green"
                        android:text="NORMAL"/>
                    <Button
                        android:id="@+id/btnDemoWarning"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/yellow"
                        android:textColor="#000000"
                        android:text="WARN"/>
                    <Button
                        android:id="@+id/btnDemoDanger"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:textSize="12sp"
                        android:backgroundTint="@color/red"
                        android:text="DANGER"/>
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
