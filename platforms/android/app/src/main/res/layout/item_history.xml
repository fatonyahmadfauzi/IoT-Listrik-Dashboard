<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:background="@drawable/bg_glass"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- Time Block (Left Column) -->
    <TextView
        android:id="@+id/tvHistTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:text="14:32:01"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvHistDate"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvHistDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:text="06 Apr 2026"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHistTime"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Guideline separates Time & Metrics visually -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideMetricsLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.30" />

    <!-- Arus -->
    <TextView
        android:id="@+id/tvHistArus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/cyan"
        android:textSize="14sp"
        android:textStyle="bold"
        android:text="0.45 A"
        app:layout_constraintStart_toEndOf="@id/guideMetricsLeft"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvHistTegangan"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Tegangan -->
    <TextView
        android:id="@+id/tvHistTegangan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/yellow"
        android:textSize="12sp"
        android:textStyle="bold"
        android:text="224 V"
        app:layout_constraintStart_toStartOf="@id/tvHistArus"
        app:layout_constraintTop_toBottomOf="@id/tvHistArus"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Status Badge (Right Column) -->
    <TextView
        android:id="@+id/tvHistStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NORMAL"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="#3322c55e"
        android:textColor="@color/green"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
